NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
DATABASE_URL="mysql://<username>:<password>@localhost:3306/<nameOfDB>"
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-with-a-long-random-secret
# Gmail API OAuth 2.0 (authorize only the gmail.send scope)
GMAIL_CLIENT_ID=your_google_oauth_client_id
GMAIL_CLIENT_SECRET=your_google_oauth_client_secret
GMAIL_REFRESH_TOKEN=your_google_oauth_refresh_token
GMAIL_SENDER_EMAIL=your-sender@gmail.com
GMAIL_SENDER_NAME=Chatting
EMAIL_VERIFICATION_CODE_TTL_MINUTES=10
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
UPLOAD_DIR=uploads
STUN_URL=stun:stun.l.google.com:19302
TURN_URL=
TURN_USERNAME=
TURN_PASSWORD=
